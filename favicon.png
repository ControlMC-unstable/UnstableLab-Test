<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" fill="none">
  <defs>
    <linearGradient id="liquid" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#a78bfa"/>
      <stop offset="100%" stop-color="#6d28d9"/>
    </linearGradient>
    <clipPath id="flask-interior">
      <path d="M 85 40 L 85 65 L 34 168 L 166 168 L 115 65 L 115 40 Z"/>
    </clipPath>
    <mask id="crack-mask">
      <rect width="200" height="200" fill="white"/>
      <!-- Erase a jagged line through the liquid so it looks split -->
      <path d="M 100 40 L 94 68 L 108 96 L 92 128 L 106 156 L 98 172"
            stroke="black" stroke-width="10" fill="none" stroke-linejoin="miter"/>
    </mask>
  </defs>

  <!-- Bubbles above the neck -->
  <circle cx="118" cy="22" r="6" fill="none" stroke="white" stroke-width="2.5"/>
  <circle cx="102" cy="10" r="8" fill="white"/>
  <circle cx="126" cy="6" r="4" fill="none" stroke="white" stroke-width="2"/>

  <!-- Liquid inside flask, split visually by the crack -->
  <g clip-path="url(#flask-interior)" mask="url(#crack-mask)">
    <path d="M 30 118 Q 60 108, 100 118 Q 140 128, 170 118 L 170 175 L 30 175 Z" fill="url(#liquid)"/>
    <circle cx="65" cy="135" r="3.5" fill="#c4b5fd" opacity="0.85"/>
    <circle cx="135" cy="145" r="2.5" fill="#6d28d9"/>
    <circle cx="82" cy="158" r="2" fill="#6d28d9"/>
    <circle cx="145" cy="160" r="2.5" fill="#c4b5fd" opacity="0.85"/>
  </g>

  <!-- Flask outline -->
  <path d="M 85 40 L 85 65 L 34 168 Q 34 172, 38 172 L 162 172 Q 166 172, 166 168 L 115 65 L 115 40"
        stroke="white" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"/>
  <!-- Neck lip -->
  <path d="M 78 40 L 122 40" stroke="white" stroke-width="6" stroke-linecap="round"/>

  <!-- Crack overlay -->
  <path d="M 100 40 L 94 68 L 108 96 L 92 128 L 106 156 L 98 172"
        stroke="white" stroke-width="4.5" fill="none" stroke-linejoin="miter" stroke-linecap="round"/>
</svg>
